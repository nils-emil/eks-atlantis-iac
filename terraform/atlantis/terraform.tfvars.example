# Copy to terraform.tfvars and fill in real values.
# terraform.tfvars is gitignored — never commit real secrets.

github_user           = "your-github-username"
github_token          = "ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
github_webhook_secret = "a-long-random-string"
repo_allowlist        = "github.com/your-org/eks-atlantis-iac"

# Optional overrides:
# region        = "us-east-1"
# namespace     = "atlantis"
# chart_version = "5.10.1"
